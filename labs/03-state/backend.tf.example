# ============================================================
# Remote Backend 配置示例（S3 + DynamoDB）
# 注意：这是示例文件，不会被 terraform 加载（.example 后缀）
# 真实使用时重命名为 backend.tf，并填入实际的 bucket 名称
# ============================================================

terraform {
  backend "s3" {
    bucket         = "your-terraform-state-bucket"   # S3 bucket 名称
    key            = "okj-study/03-state/terraform.tfstate"
    region         = "ap-northeast-1"
    encrypt        = true  # 加密存储

    # DynamoDB 表用于 state 锁，防止并发写入
    dynamodb_table = "terraform-state-lock"
  }
}

